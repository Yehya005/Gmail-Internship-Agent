# Project-local Python virtualenv
venv/

# Project-local Playwright browsers download (PLAYWRIGHT_BROWSERS_PATH)
browsers/

# Runtime IPC + log artifacts
emails.json
to_label.json
agent_output.log
*.log

# Per-cycle history fed into the Streamlit dashboard (real email content)
history.jsonl
history_*.jsonl
history_*.jsonl.bak

# Active-account config — written after the user signs in. Contains the
# user's Gmail address; never push.
account_config.json

# Local env files — keys go here when developers prefer python-dotenv
# over `setx`. Never commit. The code reads CLAUDE_CODE_OAUTH_TOKEN /
# ANTHROPIC_API_KEY / OPENAI_API_KEY from os.environ; nothing is ever
# hard-coded.
.env
.env.*
*.env

# Agent process tracking — written by the dashboard's Start/Stop buttons
agent.pid

# Python
__pycache__/
*.pyc
*.pyo

# Editor / OS
.vscode/
.idea/
.DS_Store
Thumbs.db
~$*.docx

# Claude Code project state (user-local)
.claude/
